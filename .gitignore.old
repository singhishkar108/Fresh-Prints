# ==============================================================================
# NODE.JS & RUNTIME DEPENDENCIES
# ==============================================================================

# Application, runner, and package manager logs (prevents noise in commits)
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Node.js core diagnostic/post-mortem reports 
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Process IDs and runtime locks used by process managers like PM2
pids
*.pid
*.seed
*.pid.lock

# Legacy/Instrumented code coverage folders (jscoverage / Istanbul)
lib-cov
coverage
*.lcov

# Native Istanbul (nyc) test coverage output
.nyc_output

# Build tool metadata (Grunt cache)
.grunt

# Legacy client-side package manager directory
bower_components

# Build lock file for deprecated node-waf build system
.lock-wscript

# Native C/C++ source compilation outputs
build/Release

# Core project dependencies (always pull fresh via package manager)
node_modules/
jspm_packages/

# Frontend bundler dependencies (Snowpack build cache)
web_modules/

# Incremental compilation cache to speed up subsequent TypeScript builds
*.tsbuildinfo

# Local cache for global packages and verification
.npm

# Linter caches (improves performance by only checking modified files)
.eslintcache
.stylelintcache

# Local interactive shell (REPL) command history
.node_repl_history

# Tarball artifacts generated by executing 'npm pack'
*.tgz

# Yarn v1 state file ensuring node_modules matches yarn.lock
.yarn-integrity

# ==============================================================================
# FRAMEWORKS & BUNDLERS (BUILD OUTPUTS & CACHES)
# ==============================================================================

# Bundler caches (Parcel)
.cache
.parcel-cache

# SSR and static export outputs (Next.js)
.next
out

# Development cache and production build outputs (Nuxt.js)
.nuxt
dist
.output

# Internal build cache (Gatsby)
.cache/
# Keep uncommented unless the project specifically requires tracking the public folder
# public

# Production builds and temporary dev caches (VuePress)
.vuepress/dist
.temp

# Application framework cache (SvelteKit)
.svelte-kit/

# Static site generator cache and distribution outputs (VitePress)
**/.vitepress/dist
**/.vitepress/cache

# Framework documentation build engine output (Docusaurus)
.docusaurus

# Deployment artifacts for cloud functions (Serverless Framework)
.serverless/

# Fast bundler runtime cache (FuseBox)
.fusebox/

# Local database instances for offline testing (DynamoDB Local)
.dynamodb/

# Local hosting and cloud function configurations (Firebase)
.firebase/

# Port file used for local JavaScript code-intelligence (TernJS)
.tern-port

# Test runner workspace for validating VS Code extensions
.vscode-test

# Global content-addressable storage directory (pnpm)
.pnpm-store

# Yarn Modern (v2+) Plug'n'Play runtime files and core binaries
# Note: Whitelists specific operational directories while ignoring heavy binaries
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Temporary files created by Vite during config evaluation
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
.vite/

# ==============================================================================
# ENVIRONMENT VARIABLES & CREDENTIALS (SECURITY)
# ==============================================================================

# Local environment secrets (NEVER commit; use .env.example as a template)
.env
.env.*
!.env.example

# Generic loosely-named secret files (Prevent accidental credential leaks)
*api_key*
*secret_key*
credentials.json
client_secret*.json

# Cloud provider CLI configurations containing tokens/active sessions
.aws/
.gcloud/
.vercel
.netlify

# Local database instances (Prevents bloating repo with local data)
*.db
*.sqlite
*.sqlite3

# Cryptographic private keys, certificates, and local secret overrides
*.pem
*.key
*.pfx
*.pkcs12
config/local.json
config/secrets.json

# Local Docker Swarm secrets and local multi-container development overrides
.docker-secret/
docker-compose.override.yml

# ==============================================================================
# SYSTEM, EDITOR, & IDE JUNK
# ==============================================================================

# Crash backups, swap space, and editor recovery files
*~
*.bak
*.swp
*.save

# macOS metadata, indexing files, and attributes
.DS_Store
.DS_Store?
._*

# Windows thumbnail caches and folder customization files
Thumbs.db
ehthumbs.db
desktop.ini

# Visual Studio Code workspaces and local history
.vscode/
!.vscode/extensions.json
*.code-workspace
.history/

# JetBrains (WebStorm, IntelliJ), Visual Studio, and Vim metadata
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*.swn
