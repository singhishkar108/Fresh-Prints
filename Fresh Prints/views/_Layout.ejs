<!DOCTYPE html>
<html class="scroll-smooth" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>
        <%= title %> | Fresh Prints
    </title>

    <link
        href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&amp;family=Inter:wght@400;500;600&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&amp;family=Inter:wght@400;500;600&amp;family=Sedgwick+Ave&amp;display=swap"
        rel="stylesheet" />

    <link
        href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&amp;family=Inter:wght@400;500;600&amp;family=Sedgwick+Ave&amp;family=Sedgwick+Ave+Display&amp;display=swap"
        rel="stylesheet" />

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <link rel="stylesheet" href="/css/site.css" />

    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        /* --- STAGGERED DUAL-COLOR SINGLE UNDERLINE --- */
        .nfs-nav-link {
            position: relative;
            padding-bottom: 4px;
        }

        .nfs-nav-link::before,
        .nfs-nav-link::after {
            content: '';
            position: absolute;
            left: 0;
            bottom: 0px;
            /* Both share the exact same line position */
            width: 0;
            height: 3px;
        }

        /* First phase: Pink line */
        .nfs-nav-link::before {
            background-color: #e800e8;
        }

        /* Second phase: Teal line (Layers directly on top of the pink line) */
        .nfs-nav-link::after {
            background-color: #00e3fd;
        }

        /* Trigger animations at a slower pace (0.5s) */
        .nfs-nav-link:hover::before {
            animation: nfsUnderline 0.5s cubic-bezier(0.25, 1, 0.5, 1) forwards;
        }

        .nfs-nav-link:hover::after {
            animation: nfsUnderline 0.5s cubic-bezier(0.25, 1, 0.5, 1) forwards;
            animation-delay: 0.15s;
            /* Staggered delay so teal rolls over the pink midway */
        }

        @keyframes nfsUnderline {
            0% {
                width: 0;
            }

            100% {
                width: 100%;
            }
        }
    </style>

    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#000000",
                        "on-primary": "#ffffff",
                        "secondary-fixed-dim": "#00daf3",
                        "on-surface-variant": "#444748",
                        "background": "#f9f9f9",
                        "on-background": "#1a1c1c",
                        "secondary-container": "#00e3fd",
                        "inverse-surface": "#2f3131",
                        "inverse-on-surface": "#f0f1f1",
                        "tertiary-fixed-dim": "#ffabf3",
                        "on-error-container": "#93000a",
                        "outline": "#747878"
                    },
                    spacing: {
                        "stack-sm": "8px",
                        "stack-md": "24px",
                        "stack-lg": "64px",
                        "gutter": "24px",
                        "container-max": "1440px",
                        "margin-desktop": "64px",
                        "section-gap": "128px"
                    },
                    fontFamily: {
                        "headline-lg": ["Syne"],
                        "label-bold": ["Inter"],
                        "body-md": ["Inter"],
                        "graffiti": ["Sedgwick Ave"],
                        "graffiti-display": ["Sedgwick Ave Display"]
                    },
                    fontSize: {
                        "headline-lg": ["48px", { "lineHeight": "1.1", "letterSpacing": "-0.02em", "fontWeight": "800" }],
                        "label-bold": ["14px", { "lineHeight": "1.2", "letterSpacing": "0.05em", "fontWeight": "600" }],
                        "body-md": ["16px", { "lineHeight": "1.6", "fontWeight": "400" }]
                    }
                }
            }
        }
    </script>

</head>

<body class="bg-background text-on-background font-body-md selection:bg-secondary-container selection:text-primary">

    <header class="w-full top-0 sticky z-50 bg-background border-b-2 border-primary">
        <!-- Changed items-center to items-baseline to pull right navigation links inline to the text bottom line -->
        <nav class="flex justify-between items-baseline px-margin-desktop py-4 w-full max-w-container-max mx-auto">

            <!-- Left Brand Segment -->
            <a class="group relative inline-flex items-baseline gap-4 select-none" href="/">
                <img class="h-9 w-auto object-contain transition-all group-hover:opacity-70 self-center"
                    src="/assets/FPLogo.png" alt="Fresh Prints Logo" />

                <div class="h-9 w-[1.5px] bg-primary self-center"></div>

                <span
                    class="font-headline-lg text-[29px] uppercase text-primary font-black tracking-tighter transition-all group-hover:opacity-100 leading-none">
                    FRESH PRINTS
                </span>
            </a>

            <!-- Right Navigation Segment -->
            <div class="hidden md:flex items-baseline gap-stack-lg">
                <div class="flex gap-gutter items-baseline">

                    <a class="group relative inline-flex items-center justify-center font-['Syne'] text-[13px] uppercase text-black font-bold nfs-nav-link select-none"
                        href="/products">
                        <span class="relative z-10 pointer-events-none text-black">The Catalogue</span>
                    </a>

                    <a class="group relative inline-flex items-center justify-center font-['Syne'] text-[13px] uppercase text-black font-bold nfs-nav-link select-none"
                        href="/about">
                        <span class="relative z-10 pointer-events-none text-black">Behind the Press</span>
                    </a>

                    <a class="group relative inline-flex items-center justify-center font-['Syne'] text-[13px] uppercase text-black font-bold nfs-nav-link select-none"
                        href="/contact">
                        <span class="relative z-10 pointer-events-none text-black">Connect</span>
                    </a>

                    <a class="group relative inline-flex items-center justify-center font-['Syne'] text-[13px] uppercase text-black font-bold nfs-nav-link select-none"
                        href="/terms">
                        <span class="relative z-10 pointer-events-none text-black">Terms & Conditions</span>
                    </a>

                </div>
            </div>
        </nav>
    </header>

    <main class="relative overflow-hidden">
        <%- body %>
    </main>

    <footer class="w-full mt-section-gap bg-primary dark:bg-inverse-surface border-t-4 border-secondary-container">
        <div
            class="grid grid-cols-1 md:grid-cols-12 gap-gutter px-4 md:px-margin-desktop py-stack-lg max-w-container-max mx-auto">
            <div class="md:col-span-5">
                <div class="font-headline-lg text-headline-lg text-on-primary dark:inverse-on-surface uppercase mb-6">
                    Fresh Prints
                </div>
                <p class="font-body-md text-body-md text-on-primary/70 max-w-sm">
                    High-end printing solutions for the modern rebel. We don't just print; we leave an impression.
                </p>
            </div>
            <div class="md:col-span-2 md:col-start-7">
                <h4 class="font-label-bold text-label-bold text-secondary-fixed-dim uppercase mb-4">Navigate</h4>
                <ul class="space-y-2">
                    <li><a class="font-label-bold text-label-bold text-on-primary/70 hover:opacity-100 hover:text-secondary-container transition-all"
                            href="#">Shop</a></li>
                    <li><a class="font-label-bold text-label-bold text-on-primary/70 hover:opacity-100 hover:text-secondary-container transition-all"
                            href="#">Collections</a></li>
                    <li><a class="font-label-bold text-label-bold text-on-primary/70 hover:opacity-100 hover:text-secondary-container transition-all"
                            href="#">Sitemap</a></li>
                </ul>
            </div>
            <div class="md:col-span-2">
                <h4 class="font-label-bold text-label-bold text-secondary-fixed-dim uppercase mb-4">Info</h4>
                <ul class="space-y-2">
                    <li><a class="font-label-bold text-label-bold text-on-primary/70 hover:opacity-100 hover:text-secondary-container transition-all"
                            href="#">Privacy</a></li>
                    <li><a class="font-label-bold text-label-bold text-on-primary/70 hover:opacity-100 hover:text-secondary-container transition-all"
                            href="#">Terms</a></li>
                    <li><a class="font-label-bold text-label-bold text-on-primary/70 hover:opacity-100 hover:text-secondary-container transition-all"
                            href="#">Contact</a></li>
                </ul>
            </div>
            <div class="md:col-span-2">
                <h4 class="font-label-bold text-label-bold text-secondary-fixed-dim uppercase mb-4">Connect</h4>
                <ul class="space-y-2">
                    <li><a class="font-label-bold text-label-bold text-on-primary/70 hover:opacity-100 hover:text-secondary-container transition-all"
                            href="#">Instagram</a></li>
                    <li><a class="font-label-bold text-label-bold text-on-primary/70 hover:opacity-100 hover:text-secondary-container transition-all"
                            href="#">Twitter</a></li>
                    <li><a class="font-label-bold text-label-bold text-on-primary/70 hover:opacity-100 hover:text-secondary-container transition-all"
                            href="#">LinkedIn</a></li>
                </ul>
            </div>
            <div
                class="md:col-span-12 pt-12 border-t border-on-primary/10 mt-12 flex flex-col md:flex-row justify-between items-center gap-4">
                <div class="font-label-bold text-label-bold text-on-primary/70">
                    © 2026 FRESH PRINTS. CONTROLLED CHAOS.
                </div>
                <div class="flex gap-4">
                    <span class="w-3 h-3 bg-secondary-container rounded-full animate-pulse"></span>
                    <span class="w-3 h-3 bg-tertiary-fixed-dim rounded-full animate-pulse delay-75"></span>
                    <span class="w-3 h-3 bg-on-error-container rounded-full animate-pulse delay-150"></span>
                </div>
            </div>
        </div>
    </footer>
</body>

</html>