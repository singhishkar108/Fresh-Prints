    <!-- Micro-interactions Script -->
    <script>
        // Smooth scaling effect for product cards
        document.querySelectorAll('.group').forEach(card => {
            card.addEventListener('mouseenter', () => {
                card.style.transform = 'translateY(-4px)';
                card.style.transition = 'transform 0.3s ease';
            });
            card.addEventListener('mouseleave', () => {
                card.style.transform = 'translateY(0)';
            });
        });
    </script>

    <!-- Interactive Products Banner Script -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const banner = document.getElementById('interactive-products-banner');

            if (banner) {
                banner.addEventListener('mousemove', (e) => {
                    // Calculate coordinates relative strictly to this section container bounding box
                    const rect = banner.getBoundingClientRect();
                    const x = e.clientX - rect.left;
                    const y = e.clientY - rect.top;

                    // Pass exact pixel coordinates to the CSS layout variables
                    banner.style.setProperty('--mouse-x', `${x}px`);
                    banner.style.setProperty('--mouse-y', `${y}px`);
                });
            }
        });
    </script>

